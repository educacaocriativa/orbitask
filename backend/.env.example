# ─────────────────────────────────────────────
#  ORBITASK — Environment Variables
# ─────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3333
APP_URL=http://localhost:3333
FRONTEND_URL=http://localhost:3000

# Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Database (PostgreSQL)
DATABASE_URL="postgresql://orbitask:orbitask_password@localhost:5432/orbitask_db?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# File Storage (MinIO)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=orbitask_minio
MINIO_SECRET_KEY=orbitask_minio_secret
MINIO_BUCKET=orbitask-files
MINIO_USE_SSL=false

# Evolution API (WhatsApp)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE=orbitask

# Admin
ADMIN_EMAIL=admin@orbitask.com
ADMIN_PASSWORD=Admin@123456

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

