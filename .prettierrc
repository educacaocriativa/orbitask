{
  "semi": false,
  "singleQuote": true,
  "trailingComma": "all",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "bracketSpacing": true,
  "arrowParens": "always",
  "endOfLine": "lf",
  "overrides": [
    {
      "files": "*.prisma",
      "options": { "tabWidth": 2 }
    },
    {
      "files": ["*.yml", "*.yaml"],
      "options": { "tabWidth": 2, "singleQuote": false }
    }
  ]
}

